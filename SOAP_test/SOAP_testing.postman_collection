    {
      "name": "200 ListOfContinentsByName",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Content-Type — SOAP+XML\", function () {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/soap+xml\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response includes SOAP Envelope with Body\", function () {\r",
              "    const responseXml = pm.response.text();\r",
              "\r",
              "    pm.expect(responseXml).to.include(\"<soap:Envelope\");\r",
              "    pm.expect(responseXml).to.include(\"<soap:Body\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
