				{
					"name": "201 Призвать новую сущность",
					"event": [
						{
							"listen": "test",
							"script": {
								"id": "2259f274-900d-473c-b352-d29109af628d",
								"exec": [
									"pm.test(\"Status code is 201\", function () {\r",
									"    pm.response.to.have.status(201);\r",
									"});\r",
									"// 1. Превращаем текстовый ответ сервера в понятный JSON-объект\r",
									"const jsonData = pm.response.json();\r",
									"\r",
									"// 2. Ищем в этом объекте поле с токеном. \r",
									"// В разных API оно может называться \"token\", \"access_token\" или \"blessing\"\r",
									"const newId = jsonData.id; //token – это ключ в JSON {\"token\":\"значение}\r",
									"\r",
									"// 3. Сохраняем это значение в переменную коллекции под именем \"token\"\r",
									"// Теперь это значение доступно во всей твоей коллекции через {{token}}\r",
									"pm.environment.set(\"newId\", newId);\r",
									"\r",
									"// Бонус: Выведем сообщение в консоль, чтобы убедиться, что всё прошло успешно\r",
									"console.log(\"Благословение получено и записано в Кадуцей!\");\r",
									"\r",
									"// Тест: Проверка времени ответа (Response Time)\r",
									"pm.test(\"Время ответа меньше 500ms\", function () {\r",
									"    pm.expect(pm.response.responseTime).to.be.below(500);\r",
									"});\r",
									"\r",
									"// ПРОВЕРКА ФОРМАТА (Страховка перед основным тестом)\r",
									"pm.test(\"Ответ пришел в формате JSON\", () => {\r",
									"    pm.response.to.have.header(\"Content-Type\");\r",
									"    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');\r",
									"});\r",
									"\r",
									"pm.test(\"Connection со значением keep-alive.\", () => {\r",
									"    pm.response.to.have.header(\"Connection\");\r",
									"    pm.expect(pm.response.headers.get('Connection')).to.include('keep-alive');\r",
									"});\r",
									"\r",
									"// ПРОВЕРКА РАЗМЕРА\r",
									"pm.test(\"Тело ответа содержит данные (Content-Length > 0)\", () => {\r",
									"    const length = parseInt(pm.response.headers.get('Content-Length'));\r",
									"    pm.expect(length).to.be.above(0);\r",
									"});\r",
									"\r",
									"// 1. Схема для валидации одного объекта\r",
									"const mythologySchema = {\r",
									"  \"type\": \"object\",\r",
									"  \"required\": [\"name\", \"category\", \"desc\"],\r",
									"  \"properties\": {\r",
									"    \"id\": { \"type\": \"number\" },\r",
									"    \"name\": { \"type\": \"string\" },\r",
									"    \"category\": { \"type\": \"string\" },\r",
									"    \"desc\": { \"type\": \"string\" },\r",
									"    \"img\": { \"type\": \"string\" }\r",
									"  }\r",
									"};\r",
									"\r",
									"// 2. Проверка соответствия ответа схеме\r",
									"pm.test(\"Схема ответа валидна (MythologyEntity)\", function () {\r",
									"    pm.response.to.have.jsonSchema(mythologySchema);\r",
									"});\r",
									"\r",
									"// 3. Проверка что это объект\r",
									"pm.test(\"Ответ является объектом\", function () {\r",
									"    pm.expect(pm.response.json()).to.be.an('object');\r",
									"});"
								],
