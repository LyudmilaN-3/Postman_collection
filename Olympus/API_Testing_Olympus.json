				{
					"name": "200 Вход и получение токена",
					"event": [
						{
							"listen": "test",
							"script": {
								"id": "2e4fb4a5-3c57-4c75-a5c1-0eff2ead6ab9",
								"exec": [
									"pm.test(\"Status code is 200\", function () {\r",
									"    pm.response.to.have.status(200);\r",
									"});\r",
									"\r",
									"// 1. Превращаем текстовый ответ сервера в понятный JSON-объект\r",
									"const jsonData = pm.response.json();\r",
									"\r",
									"// 2. Ищем в этом объекте поле с токеном. \r",
									"// В разных API оно может называться \"token\", \"access_token\" или \"blessing\"\r",
									"const myToken = jsonData.token; //token – это ключ в JSON {\"token\":\"значение}\r",
									"\r",
									"// 3. Сохраняем это значение в переменную коллекции под именем \"token\"\r",
									"// Теперь это значение доступно во всей твоей коллекции через {{token}}\r",
									"pm.environment.set(\"token\", myToken);\r",
									"\r",
									"// Бонус: Выведем сообщение в консоль, чтобы убедиться, что всё прошло успешно\r",
									"console.log(\"Благословение получено и записано в Кадуцей!\");\r",
									"\r",
									"// Тест: Проверка времени ответа (Response Time)\r",
									"pm.test(\"Время ответа меньше 400ms\", function () {\r",
									"    pm.expect(pm.response.responseTime).to.be.below(400);\r",
									"});\r",
									"\r",
									"pm.test(\"Content-Type is present\", function () {\r",
									"    pm.response.to.have.header(\"Content-Type\");\r",
									"});\r",
									"\r",
									"pm.test(\"Token is present\", function () {\r",
									"    var jsonData = pm.response.json();\r",
									"    pm.expect(jsonData.token).to.include.a(\"string\");\r",
									"});\r",
									""
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
